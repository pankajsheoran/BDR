{
  "manifest_version": 3,
  "name": "BDR Test Extension",
  "version": "1.0",
  "description": "Simulates form field access for BDR testing",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BDR Test"
  }
}