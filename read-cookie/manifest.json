{
  "manifest_version": 3,
  "name": "Cookie Logger",
  "version": "1.2",
  "description": "Reads all accessible cookies and shows them in popup",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cookie Logger",
    "default_popup": "popup.html"
  }
}